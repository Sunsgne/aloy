generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TenantStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum SiteStatus {
  ACTIVE
  DISABLED
}

enum DeviceStatus {
  PENDING
  ONBOARDING
  ONLINE
  OFFLINE
  ERROR
  DISABLED
}

enum OnboardingMode {
  CLEAN_BOOTSTRAP
  ADOPT_EXISTING
  MONITORING_ONLY
  POP_NODE
}

enum OnboardingStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum DevicePlatformType {
  ROUTERBOARD
  CHR
  X86
  CLOUD_INSTANCE
  UNKNOWN
}

enum DeviceCertificationStatus {
  DISCOVERED
  IDENTIFIED
  CAPABILITY_PROBED
  CERTIFIED
  PARTIALLY_CERTIFIED
  UNSUPPORTED
  QUARANTINED
}

enum DeviceCapabilityStatus {
  SUPPORTED
  SUPPORTED_WITH_LIMITS
  UNSUPPORTED
  DISABLED_BY_PACKAGE
  DISABLED_BY_DEVICE_MODE
  UNSUPPORTED_VERSION
  UNSUPPORTED_PLATFORM
  UNKNOWN
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  status        TenantStatus   @default(ACTIVE)
  users         User[]
  roles         Role[]
  subscriptions Subscription[]
  apiTokens     ApiToken[]
  auditEvents   AuditEvent[]
  sites         Site[]
  devices       Device[]
  bootstrapTokens BootstrapToken[]
  onboardingSessions OnboardingSession[]
  deviceIdentities DeviceIdentity[]
  deviceCredentials DeviceCredential[]
  devicePackages DevicePackage[]
  deviceCapabilities DeviceCapability[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     String
  updatedBy     String
  deletedAt     DateTime?
}

model Site {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  name        String
  code        String
  description String?
  timezone    String     @default("UTC")
  status      SiteStatus @default(ACTIVE)
  devices     Device[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   String
  updatedBy   String
  deletedAt   DateTime?

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Device {
  id                 String              @id @default(cuid())
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  siteId             String
  site               Site                @relation(fields: [siteId], references: [id])
  name               String
  serialNumber       String?
  model              String?
  routerOsVersion    String?
  managementAddress  String?
  status             DeviceStatus        @default(PENDING)
  onboardingMode     OnboardingMode?
  lastSeenAt         DateTime?
  bootstrapTokens    BootstrapToken[]
  onboardingSessions OnboardingSession[]
  identity           DeviceIdentity?
  credentials        DeviceCredential[]
  packages           DevicePackage[]
  capabilities       DeviceCapability[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdBy          String
  updatedBy          String
  deletedAt          DateTime?

  @@unique([tenantId, name])
  @@index([tenantId, siteId])
}

model DeviceIdentity {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  deviceId         String   @unique
  device           Device   @relation(fields: [deviceId], references: [id])
  fingerprint      String?  @unique
  platformType     DevicePlatformType @default(UNKNOWN)
  certificationStatus DeviceCertificationStatus @default(DISCOVERED)
  identity         String?
  boardName        String?
  serialNumber     String?
  softwareId       String?
  systemId         String?
  model            String?
  revision         String?
  architectureName String?
  cpu              String?
  cpuCount         Int?
  cpuFrequencyMhz  Int?
  totalMemoryBytes Float?
  totalStorageBytes Float?
  routerOsVersion  String?
  buildTime        String?
  factorySoftware  String?
  licenseLevel     String?
  currentFirmware  String?
  upgradeFirmware  String?
  deviceMode       String?
  deviceModeFlagged Boolean?
  deviceModeFeatures String[] @default([])
  lastReportedAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdBy        String
  updatedBy        String
  deletedAt        DateTime?

  @@index([tenantId])
}

model DeviceCredential {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  deviceId     String
  device       Device   @relation(fields: [deviceId], references: [id])
  label        String
  secretHash   String   @unique
  lastSequence Int      @default(0)
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String
  updatedBy    String
  deletedAt    DateTime?

  @@index([tenantId, deviceId])
}

model DevicePackage {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id])
  name      String
  version   String
  disabled  Boolean  @default(false)
  scheduled Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  updatedBy String
  deletedAt DateTime?

  @@index([tenantId, deviceId])
}

model DeviceCapability {
  id        String                 @id @default(cuid())
  tenantId  String
  tenant    Tenant                 @relation(fields: [tenantId], references: [id])
  deviceId  String
  device    Device                 @relation(fields: [deviceId], references: [id])
  key       String
  status    DeviceCapabilityStatus
  reason    String?
  observedAt DateTime              @default(now())
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  createdBy String
  updatedBy String
  deletedAt DateTime?

  @@index([tenantId, deviceId])
}

model BootstrapToken {
  id         String         @id @default(cuid())
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  deviceId   String
  device     Device         @relation(fields: [deviceId], references: [id])
  mode       OnboardingMode
  tokenHash  String         @unique
  expiresAt  DateTime
  consumedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime       @default(now())
  createdBy  String

  @@index([tenantId, deviceId])
}

model OnboardingSession {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  deviceId    String
  device      Device           @relation(fields: [deviceId], references: [id])
  mode        OnboardingMode
  status      OnboardingStatus @default(PENDING)
  currentStep String?
  progress    Int              @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  managementPlan Json?
  adoptionReport Json?
  steps       OnboardingStep[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdBy   String

  @@index([tenantId, createdAt])
  @@index([deviceId, createdAt])
}

model OnboardingStep {
  id        String           @id @default(cuid())
  sessionId String
  session   OnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  key       String
  label     String
  position  Int
  status    OnboardingStatus @default(PENDING)
  startedAt DateTime?
  endedAt   DateTime?
  error     String?

  @@unique([sessionId, key])
  @@index([sessionId, position])
}

model User {
  id           String     @id @default(cuid())
  tenantId     String?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])
  email        String
  passwordHash String
  displayName  String
  status       UserStatus @default(ACTIVE)
  userRoles    UserRole[]
  refreshTokens RefreshToken[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdBy    String
  updatedBy    String
  deletedAt    DateTime?

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Role {
  id          String           @id @default(cuid())
  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  userRoles   UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdBy   String
  updatedBy   String
  deletedAt   DateTime?

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model UserRole {
  userId     String
  roleId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())
  assignedBy String

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Subscription {
  id             String             @id @default(cuid())
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  planKey        String
  status         SubscriptionStatus @default(ACTIVE)
  siteLimit      Int
  deviceLimit    Int
  bandwidthMbps  Int
  dnsNodeScopes  String[]
  startsAt       DateTime
  endsAt         DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  @@index([tenantId])
}

model ApiToken {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  name       String
  tokenHash  String   @unique
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  deletedAt  DateTime?

  @@index([tenantId])
}

model AuditEvent {
  id             String   @id @default(cuid())
  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  actorUserId    String
  action         String
  resourceType   String
  resourceId     String?
  requestId      String
  accessReason   String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
}
